    10     <style>
    11         :root {
    12             --gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc
       100%);
    13             --shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    14             --shadow-hover: 0 15px 45px rgba(0, 0, 0, 0.25);       
    15         }
    16
    17         body {
    18             font-family: 'Roboto', sans-serif;
    19             background-color: #f0f2f5;
    20             display: flex;
    21             justify-content: center;
    22             align-items: center;
    23             min-height: 100vh;
    24             margin: 0;
    25         }
    26
    27         .profile-card {
    28             background: var(--gradient);
    29             width: 320px;
    30             padding: 40px 30px;
    31             border-radius: 24px;
    32             text-align: center;
    33             color: white;
    34             box-shadow: var(--shadow);
    35             transition: transform 0.3s ease, box-shadow 0.3s ease; 
    36             cursor: pointer;
    37         }
    38
    39         .profile-card:hover {
    40             transform: translateY(-10px);
    41             box-shadow: var(--shadow-hover);
    42         }
    43
    44         .profile-image-container {
    45             width: 120px;
    46             height: 120px;
    47             margin: 0 auto 20px;
    48             border-radius: 50%;
    49             border: 4px solid rgba(255, 255, 255, 0.3);
    50             overflow: hidden;
    51             background-color: rgba(255, 255, 255, 0.1);
    52             display: flex;
    53             align-items: center;
    54             justify-content: center;
    55         }
    56
    57         .profile-image-placeholder {
    58             width: 100%;
    59             height: 100%;
    60             background: #eee;
    61             display: flex;
    62             align-items: center;
    63             justify-content: center;
    64             font-size: 40px;
    65             color: #6a11cb;
    66         }
    67
    68         .name {
    69             margin: 0;
    70             font-size: 24px;
    71             font-weight: 700;
    72             letter-spacing: 0.5px;
    73         }
    74
    75         .stream {
    76             font-size: 14px;
    77             font-weight: 500;
    78             text-transform: uppercase;
    79             letter-spacing: 2px;
    80             margin: 8px 0 20px;
    81             opacity: 0.9;
    82         }
    83
    84         .bio {
    85             font-size: 15px;
    86             line-height: 1.6;
    87             font-weight: 300;
    88             margin: 0;
    89             opacity: 0.85;
    90         }
    91     </style>
    92 </head>
